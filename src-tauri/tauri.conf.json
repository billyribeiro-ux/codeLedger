{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeLedger",
  "version": "3.0.0",
  "identifier": "app.codeledger.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeLedger",
        "width": 1100,
        "height": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Developer learning tracker",
    "longDescription": "Track languages, notes, goals, study sessions, and Pomodoro focus time with local SQLite storage."
  }
}
